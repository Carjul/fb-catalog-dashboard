# Meta Marketing API
FB_ACCESS_TOKEN=EAAB...your_long_lived_token_here
FB_API_VERSION=v21.0

# Public base URL (for CSV feed endpoint that Meta will scrape)
# Local dev: http://localhost:${PORT}
# Production: https://your-app.onrender.com
PUBLIC_BASE_URL=http://localhost:5000

# App port
PORT=5000

# Session secret (random string)
SESSION_SECRET=change-me-to-a-random-long-string

# MongoDB
MONGODB_URI=mongodb+srv://admin:12345@cluster0.losq7.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=fb_catalog_dashboard

# Trick runner cron interval (seconds, default 3600 = 1h)
TRICK_RUNNER_INTERVAL=3600
